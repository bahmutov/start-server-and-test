{
  "configMigration": true,
  "extends": ["config:recommended"],
  "automerge": true,
  "major": {
    "automerge": false
  },
  "dependencyDashboard": true,
  "schedule": ["before 2am"],
  "updateNotScheduled": false,
  "timezone": "America/New_York",
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "*",
        "!/bluebird/",
        "!/check-more-types/",
        "!/debug/",
        "!/execa/",
        "!/lazy-ass/",
        "!/ps-tree/",
        "!/wait-on/"
      ]
    }
  ]
}
